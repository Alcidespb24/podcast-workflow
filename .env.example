# Podcast Workflow - Environment Configuration
# Copy this file to .env and fill in your values.
#
# Generate a password hash:
#   python -m src.hash_password

# =============================================================================
# REQUIRED - The app will not start without these
# =============================================================================

GOOGLE_API_KEY=your-google-api-key-here
BASE_URL=https://your-domain.com
VAULT_BASE_DIR=/path/to/obsidian/vault
VAULT_OUTPUT_DIR=/path/to/obsidian/vault/output
DASHBOARD_PASSWORD_HASH=$argon2id$... (run: python -m src.hash_password)
SESSION_SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# =============================================================================
# OPTIONAL - Uncomment and change to override defaults
# =============================================================================

